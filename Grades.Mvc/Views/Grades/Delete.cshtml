@model Grades.Mvc.ViewModels.GradeViewModel

@{
    ViewData["Title"] = "Delete Grade";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-danger mb-0">
                <i class="bi bi-trash-fill me-2"></i>
                Delete Grade
            </h2>

            <small class="text-muted">
                Confirm grade deletion
            </small>
        </div>

        <a asp-action="Index" class="btn btn-outline-dark">
            <i class="bi bi-arrow-left me-1"></i>
            Back to List
        </a>

    </div>

    <!-- Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <!-- Card Header -->
        <div class="card-header bg-danger text-white py-3 px-4">
            <span class="fw-semibold text-uppercase small">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Warning
            </span>
        </div>

        <!-- Card Body -->
        <div class="card-body p-4">

            <div class="alert alert-danger rounded-3 mb-4">
                <i class="bi bi-exclamation-circle-fill me-2"></i>
                Are you sure you want to permanently delete this grade?
            </div>

            <!-- Details -->
            <div class="row g-4">

                <!-- Student -->
                <div class="col-md-6">
                    <div class="border rounded-4 p-3 bg-light h-100">

                        <small class="text-muted text-uppercase fw-semibold">
                            Student
                        </small>

                        <div class="fw-bold fs-5 mt-1">
                            <i class="bi bi-person-fill text-primary me-1"></i>
                            @Model.StudentName
                        </div>

                    </div>
                </div>

                <!-- Course -->
                <div class="col-md-6">
                    <div class="border rounded-4 p-3 bg-light h-100">

                        <small class="text-muted text-uppercase fw-semibold">
                            Course
                        </small>

                        <div class="fw-bold fs-5 mt-1">
                            <i class="bi bi-book-fill text-primary me-1"></i>
                            @Model.CourseName
                        </div>

                    </div>
                </div>

                <!-- Score -->
                <div class="col-md-6">
                    <div class="border rounded-4 p-3 bg-light h-100">

                        <small class="text-muted text-uppercase fw-semibold">
                            Score
                        </small>

                        <div class="mt-2">

                            @if (Model.Score >= 85)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fs-6">
                                    @Model.Score
                                </span>
                            }
                            else if (Model.Score >= 60)
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 fs-6">
                                    @Model.Score
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 fs-6">
                                    @Model.Score
                                </span>
                            }

                        </div>

                    </div>
                </div>

                <!-- Grade Date -->
                <div class="col-md-6">
                    <div class="border rounded-4 p-3 bg-light h-100">

                        <small class="text-muted text-uppercase fw-semibold">
                            Grade Date
                        </small>

                        <div class="fw-semibold fs-6 mt-2">
                            <i class="bi bi-calendar-event-fill text-primary me-1"></i>
                            @Model.GradeDate.ToShortDateString()
                        </div>

                    </div>
                </div>

            </div>

            <!-- Buttons -->
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">

                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-danger px-4">

                        <i class="bi bi-trash-fill me-1"></i>
                        Delete
                    </button>

                    <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">

                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </div>
</div>