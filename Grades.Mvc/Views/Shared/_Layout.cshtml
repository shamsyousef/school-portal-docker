    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Grades.Mvc</title>

        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Grades.Mvc.styles.css" asp-append-version="true" />
    </head>

    <body>

        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg shadow-sm"
             style="background: linear-gradient(135deg, #1f2937, #111827); padding: 14px 0;">

            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand text-white fw-bold fs-3"
                       asp-controller="Grades"
                       asp-action="Index">
                    🧾 Grades 
                </a>

                <!-- NAV LINKS -->
                <div class="d-flex align-items-center gap-3">

                    <a class="btn btn-outline-light rounded-pill px-4"
                           asp-controller="Grades"
                           asp-action="Index">
                        Grades
                    </a>

                    <a class="btn btn-outline-light rounded-pill px-4"
                           href="http://localhost:5001/Students">
                        Students
                    </a>

                </div>

            </div>
        </nav>

        <!-- BODY -->
        <div class="container mt-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <!-- FOOTER -->
        <footer class="border-top footer text-muted mt-4">
            <div class="container">
                &copy; 2026 - Grades.Mvc
            </div>
        </footer>

        <!-- SCRIPTS -->
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)

    </body>
</html>
