@model Students.Mvc.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">

    <div class="card border-danger shadow-sm">

        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">⚠ Delete Student</h3>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Are you sure you want to delete this student? This action cannot be undone.
            </div>

            <div class="row">

                <div class="col-md-6 mb-2">
                    <strong>First Name:</strong> @Model.FirstName
                </div>

                <div class="col-md-6 mb-2">
                    <strong>Last Name:</strong> @Model.LastName
                </div>

                <div class="col-md-12 mb-2">
                    <strong>Email:</strong> @Model.Email
                </div>

                <div class="col-md-6 mb-2">
                    <strong>Date Of Birth:</strong> @Model.DateOfBirth.ToShortDateString()
                </div>

                <div class="col-md-6 mb-2">
                    <strong>Enrollment Date:</strong> @Model.EnrollmentDate.ToShortDateString()
                </div>

            </div>

            <form asp-action="Delete" class="mt-3">

                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        ← Cancel
                    </a>

                    <button type="submit" class="btn btn-danger">
                        🗑 Yes, Delete
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
