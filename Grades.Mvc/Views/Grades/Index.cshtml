@model IEnumerable<Grades.Mvc.ViewModels.GradeViewModel>

@{
    ViewData["Title"] = "Grades";
    int counter = 0;
    int total = Model.Count();
}

<div class="container-lg py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">
                <i class="bi bi-journal-check text-primary me-2"></i>Grades List
            </h2>
            <small class="text-muted">All student grades and scores</small>
        </div>

        <a asp-action="Create" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg me-1"></i>
            Add Grade
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <!-- Card Header -->
        <div class="card-header bg-dark text-white py-3 px-4 d-flex justify-content-between align-items-center">
            <span class="fw-semibold text-uppercase small">
                <i class="bi bi-table me-2"></i>
                Grades Table
            </span>

        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                      

                        <th class="text-muted small text-uppercase fw-semibold">
                            Student
                        </th>

                        <th class="text-muted small text-uppercase fw-semibold">
                            Course
                        </th>

                        <th class="text-muted small text-uppercase fw-semibold">
                            Score
                        </th>

                        <th class="text-muted small text-uppercase fw-semibold">
                            Grade Date
                        </th>

                        <th class="text-center text-muted small text-uppercase fw-semibold" style="width:140px">
                            Actions
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        counter++;

                        <tr>

                          

                            <!-- Student -->
                            <td>
                                <div class="d-flex align-items-center gap-2">

                                   

                                    <div>
                                        <div class="fw-semibold text-dark">
                                            @item.StudentName
                                        </div>
                                    </div>

                                </div>
                            </td>

                            <!-- Course -->
                            <td>
                                <span class="fw-medium text-dark">
                                    @item.CourseName
                                </span>
                            </td>

                            <!-- Score -->
                            <td>
                                @if (item.Score >= 85)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                        @item.Score
                                    </span>
                                }
                                else if (item.Score >= 60)
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                        @item.Score
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                        @item.Score
                                    </span>
                                }
                            </td>

                            <!-- Date -->
                            <td>
                                <span class="text-muted small">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @item.GradeDate.ToShortDateString()
                                </span>
                            </td>

                            <!-- Actions -->
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">

                                    <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-info"
                                           title="Details"
                                           data-bs-toggle="tooltip">

                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-warning"
                                           title="Edit"
                                           data-bs-toggle="tooltip">

                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger"
                                           title="Delete"
                                           data-bs-toggle="tooltip">

                                        <i class="bi bi-trash"></i>
                                    </a>

                                </div>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        </div>

        <!-- Footer -->
        <div class="card-footer bg-light border-0 px-4 py-3">
            <div class="d-flex align-items-center gap-2 text-muted small">

                <i class="bi bi-info-circle"></i>

                Showing

                <span class="badge bg-dark rounded-pill">
                    @total
                </span>

                grade@(total != 1 ? "s" : "") in total
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('[data-bs-toggle="tooltip"]')
            .forEach(el => new bootstrap.Tooltip(el));
    </script>
}