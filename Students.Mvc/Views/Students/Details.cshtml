@model Students.Mvc.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container-lg py-4">

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-dark text-white py-3 px-4">
            <i class="bi bi-person-lines-fill me-2"></i> Student Details
        </div>

        <div class="card-body p-4">

            <div class="row g-3">

                <div class="col-md-6">
                    <strong>First Name:</strong>
                    <div class="text-muted">@Model.FirstName</div>
                </div>

                <div class="col-md-6">
                    <strong>Last Name:</strong>
                    <div class="text-muted">@Model.LastName</div>
                </div>

                <div class="col-12">
                    <strong>Email:</strong>
                    <div class="text-muted">@Model.Email</div>
                </div>

                <div class="col-md-6">
                    <strong>Date Of Birth:</strong>
                    <div class="text-muted">@Model.DateOfBirth.ToShortDateString()</div>
                </div>

                <div class="col-md-6">
                    <strong>Enrollment Date:</strong>
                    <div class="text-muted">@Model.EnrollmentDate.ToShortDateString()</div>
                </div>

            </div>

            <div class="d-flex justify-content-between mt-4">

                <a asp-action="Index" class="btn btn-secondary">← Back</a>

                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        ✏ Edit
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>